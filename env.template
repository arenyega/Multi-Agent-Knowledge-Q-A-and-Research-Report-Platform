# AI Agents Environment Configuration for ModelScope/OpenAI-compatible API
# Copy this file to .env and fill in your real keys.
# Do not commit .env to Git.

# ModelScope OpenAI-compatible API
OPENAI_BASE_URL=https://api-inference.modelscope.cn/v1
OPENAI_API_KEY=
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash

# Optional: remote text embedding model.
# If left empty, the project uses a deterministic local hash embedding fallback.
# For better retrieval quality, set this to an embedding model available in your ModelScope account.
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
LOCAL_EMBEDDING_DIM=768
RETRIEVER_TOP_K=4

# Tavily web search API. Required for Deep Research and optional web enhancement in PDF RAG.
TAVILY_API_KEY=

# Database Configuration
# For Docker Compose the backend service overrides QDRANT_HOST to qdrant.
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Development Configuration
PYTHONPATH=./src

# Optional: force PDF RAG to never route questions to Tavily web search.
FORCE_VECTORSTORE=false
